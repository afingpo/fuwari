---

import { getEntry, render } from "astro:content";
import Markdown from "@components/misc/Markdown.astro";
import I18nKey from "../i18n/i18nKey";
import { i18n } from "../i18n/translation";
import MainGridLayout from "../layouts/MainGridLayout.astro";

const essayPost = await getEntry("spec", "essay");

if (!aboutPost) {
        throw new Error("Essay page content not found");
}

const { Content } = await render(essayPost);
---
<MainGridLayout title={i18n(I18nKey.essay)} description={i18n(I18nKey.essay)}>
    <div class="flex w-full rounded-[var(--radius-large)] overflow-hidden relative min-h-32">
        <div class="card-base z-10 px-9 py-6 relative w-full ">
            <Markdown class="mt-2">
                <Content />
            </Markdown>
        </div>
    </div>
</MainGridLayout>

---
/* 构建时拉取 Memos —— 只改这里的路径 */
const MEMOS_API = 'https://memo.yourdomain.com';   // ← 你的实例
const LIMIT     = 30;
const api       = `${MEMOS_API}/api/v1/memo?limit=${LIMIT}&rowStatus=NORMAL`;

let memos: any[] = [];
try {
  const res = await fetch(api, { headers: { Accept: 'application/json' } });
  if (res.ok) memos = await res.json();
} catch (e) {
  console.warn('[Memos SSG]', e);
}
---

<!-- 原有随笔正文上方或下方想放 Memos 的地方插： -->
<section class="not-prose mt-12">
  <h2 class="text-2xl font-bold mb-4">💬 随 手 记</h2>

  <!-- 首次渲染 -->
  <div id="memos-list" class="space-y-4">
    {memos.length === 0 && (
      <p class="text-gray-500 dark:text-gray-400">暂无内容，去写第一条 Memo 吧～</p>
    )}
    {memos.map((m) => (
      <div
        class="memo-card border border-[var(--color-border)] rounded-xl p-4 shadow-sm
               bg-[var(--color-bg)] dark:bg-[var(--color-bg-dark)]"
      >
        <div class="content prose prose-sm dark:prose-invert max-w-none mb-2"
             set:html={enhance(m.content)} />
        <time class="text-xs text-gray-400" datetime={String(m.createdTs)}>
          {new Date(m.createdTs * 1000).toLocaleString('zh-CN', {
            dateStyle: 'short',
            timeStyle: 'short',
          })}
        </time>
      </div>
    ))}
  </div>

  <footer class="mt-6 text-xs text-gray-400">
    每 30 秒自动同步最新内容
  </footer>
</section>

<!-- 客户端增量脚本 -->
<script is:inline define:vars={{ MEMOS_API, LIMIT }}>
  /* ====== 客户端增量拉取 ====== */
  const INTERVAL = 30_000;
  const $list    = document.getElementById('memos-list');
  let newestTs   = 0;

  initClient();
  function initClient() {
    const times = Array.from($list.querySelectorAll('time'))
      .map((t) => Number(t.getAttribute('datetime')))
      .filter((n) => !isNaN(n));
    if (times.length) newestTs = Math.max(...times);
    setInterval(pullNew, INTERVAL);
  }

  async function pullNew() {
    try {
      const res = await fetch(
        `${MEMOS_API}/api/v1/memo?limit=20&rowStatus=NORMAL&createdTsAfter=${newestTs}`
      );
      if (!res.ok) return;
      const list = await res.json();
      if (!list.length) return;
      list.reverse().forEach((m) => prependCard(m));
      newestTs = Math.max(newestTs, ...list.map((m) => m.createdTs));
    } catch (e) {
      console.warn('[Memos pull]', e);
    }
  }

  function prependCard(m: any) {
    const node = renderCard(m);
    $list.prepend(node);
    node.animate([{ opacity: 0, transform: 'translateY(-10px)' },
                  { opacity: 1, transform: 'none' }], 300);
  }

  function renderCard(m: any): HTMLElement {
    const wrap = document.createElement('div');
    wrap.className = `memo-card border border-[var(--color-border)] rounded-xl p-4 shadow-sm
                      bg-[var(--color-bg)] dark:bg-[var(--color-bg-dark)]`;
    wrap.innerHTML = `
      <div class="content prose prose-sm dark:prose-invert max-w-none mb-2">
        ${enhance(m.content)}
      </div>
      <time class="text-xs text-gray-400" datetime="${m.createdTs}">
        ${new Date(m.createdTs * 1000).toLocaleString('zh-CN', {
          dateStyle: 'short',
          timeStyle: 'short',
        })}
      </time>`;
    return wrap;
  }

  function enhance(txt: string) {
    return txt
      .replace(/```(\w+)?\n([\s\S]*?)```/g, '<pre><code class="language-$1">$2</code></pre>')
      .replace(/`([^`]+)`/g, '<code>$1</code>')
      .replace(/(https?:\/\/[^\s]+)/g, '<a href="$1" target="_blank" rel="noreferrer">$1</a>')
      .replace(/(@\w+)/g, '<span class="text-sky-600 font-semibold">$1</span>')
      .replace(/(#\w+)/g, '<span class="text-indigo-600 font-semibold">$1</span>');
  }
</script>

<style>
  /* 让卡片更圆润，与 Fuwari 默认风格融合 */
  .memo-card {
    transition: box-shadow 0.2s;
  }
  .memo-card:hover {
    box-shadow: 0 0 0 2px var(--color-primary);
  }
  pre {
    @apply bg-gray-100 dark:bg-gray-800 p-3 rounded text-sm overflow-auto;
  }
  code {
    @apply text-pink-600 dark:text-pink-400;
  }
</style>

