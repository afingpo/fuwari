---
// src/pages/essay.astro
import { getCollection } from "astro:content";
import MainGridLayout from "../layouts/MainGridLayout.astro";
import PostCard from "@components/PostCard.astro";
import { i18n } from "../i18n/translation";
import I18nKey from "../i18n/i18nKey";

const essays = await getCollection("posts", ({ data }) => {
    return (import.meta.env.PROD ? data.draft !== true : true)
        && data.pType === "essay"
        && data.published;
});

essays.sort((a, b) => {
    const dateA = a.data.published ? new Date(a.data.published).getTime() : 0;
    const dateB = b.data.published ? new Date(b.data.published).getTime() : 0;
    return dateB - dateA;
});
---

<MainGridLayout title={i18n(I18nKey.essay)} description="诗词、散文与感悟">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
		{essays.map((post) => {
    	// 处理掉 id 中的 .md 后缀，生成干净的 URL
    	const cleanId = post.id.replace(/\.md$/, '');
			return (
        	<PostCard
            	entry={post}
            	title={post.data.title}
        		url={`/posts/${cleanId}/`} 
            	published={post.data.published}
            	updated={post.data.updated}
            	tags={post.data.tags || []}
            	category={post.data.category || null}
            	image={post.data.image}
            	description={post.data.description || ""}
            	draft={post.data.draft || false}
				style={post.data.style || ""}
        	/>
    	)
		})}
	</div>

	{essays.length === 0 && (
        <div class="card-base p-10 text-center text-black/50 dark:text-white/50">
            还没有迁移散文内容。
        </div>
    )}
</MainGridLayout>

