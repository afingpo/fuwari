---
// src/pages/essay.astro
import { getCollection } from "astro:content";
import MainGridLayout from "../layouts/MainGridLayout.astro";
import MiniCard from "@components/MiniCard.astro";
import { i18n } from "../i18n/translation";
import I18nKey from "../i18n/i18nKey";

const essays = await getCollection("posts", ({ data }) => {
    return (import.meta.env.PROD ? data.draft !== true : true)
        && data.pType === "essay"
        && data.published;
});

essays.sort((a, b) => {
    const dateA = a.data.published ? new Date(a.data.published).getTime() : 0;
    const dateB = b.data.published ? new Date(b.data.published).getTime() : 0;
    return dateB - dateA;
});
---

<MainGridLayout title={i18n(I18nKey.essay)} description="诗词、散文与感悟">
    <div class="essay-grid grid grid-cols-1 md:grid-cols-2 gap-4">
		{essays.map((post) => (
			<MiniCard
                title={post.data.title}
                url={`/posts/${post.id.replace(/\.md$/, '')}/`}
                published={post.data.published}
				era={post.data.era}
				showEnterBtn={false}
            />
        ))}
    </div>
    
</MainGridLayout>

