---
// src/pages/essay.astro
import { getCollection } from "astro:content";
import MainGridLayout from "../layouts/MainGridLayout.astro";
import PostCard from "@components/PostCard.astro";
import { i18n } from "../i18n/translation";
import I18nKey from "../i18n/i18nKey";

const essays = await getCollection("posts", ({ data }) => {
    return (import.meta.env.PROD ? data.draft !== true : true)
        && data.pType === "essay"
        && data.published;
});

essays.sort((a, b) => {
    const dateA = a.data.published ? new Date(a.data.published).getTime() : 0;
    const dateB = b.data.published ? new Date(b.data.published).getTime() : 0;
    return dateB - dateA;
});
---

<MainGridLayout title={i18n(I18nKey.essay)} description="诗词、散文与感悟">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
		{essays.map((post) => (
    		<PostCard
        		entry={post}
        		title={post.data.title}
        		url={`/posts/${post.id.replace(/\.md$/, '')}/`} 
        		published={post.data.published}
        		/* 以下字段全部设为空或隐藏 */
        		updated={null}
        		tags={[]} 
        		category={null}
        		image={null} 
        		description={""} 
        		words={0}
        		draft={false}
    		/>
		))}
	</div>

	{essays.length === 0 && (
        <div class="card-base p-10 text-center text-black/50 dark:text-white/50">
            还没有迁移散文内容。
        </div>
    )}
</MainGridLayout>

