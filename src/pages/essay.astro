---
/**
 * Fuwari 博客专用 Memos 页面
 * 构建时拉取 + 客户端增量更新
 * 作者：Kimi
 */

import Layout from '@layouts/Layout.astro';   // Fuwari 自带布局
import Container from '@components/Container.astro';

/***************  用户配置区  ****************/
const MEMOS_API = 'https://memos.s1.afingpo.top';   // 去掉末尾 /
const LIMIT     = 30;                              // 首次拉取条数
/********************************************/

const api = `${MEMOS_API}/api/v1/memo?limit=${LIMIT}&rowStatus=NORMAL`;

let memos: any[] = [];
try {
  const res = await fetch(api, { headers: { 'Accept': 'application/json' } });
  if (res.ok) memos = await res.json();
} catch (e) {
  console.warn('[Memos SSG] 获取失败', e);
}
---

<Layout title="Memos" description="碎碎念与速记">
  <Container>
    <h1 class="text-3xl font-bold mb-6">Memos</h1>

    <!-- 客户端会覆盖这里 -->
    <div id="memos-list" class="space-y-4">
      {memos.length === 0 && <p class="text-gray-500">暂无内容，去写第一条 Memo 吧～</p>}
      {memos.map(m => <MemoCard memo={m} />)}
    </div>

    <footer class="mt-10 text-sm text-gray-400">
      实时更新中，每 30 秒自动同步最新内容
    </footer>
  </Container>
</Layout>

<!-- 单条 Memo 卡片组件 -->
<template id="memo-card-tpl">
  <div class="memo-card border border-base rounded-xl p-4 shadow-sm">
    <div class="content prose prose-sm dark:prose-invert max-w-none mb-2"></div>
    <time class="text-xs text-gray-400"></time>
  </div>
</template>

<script>
  /****************  客户端增量更新  ****************/
  const MEMOS_API   = 'https://memo.yourdomain.com'; // 与上方保持一致
  const LIMIT       = 30;
  const INTERVAL    = 30 * 1000;                     // 30 秒
  const $list       = document.getElementById('memos-list') as HTMLDivElement;
  const cardTpl     = document.getElementById('memo-card-tpl') as HTMLTemplateElement;

  let newestTs = 0;            // 当前最新 memo 的时间戳
  initClient();

  /* 首次挂载后，把构建时已有的卡片时间记录下来 */
  function initClient() {
    const times = Array.from($list.querySelectorAll('time'))
      .map(t => Number(t.getAttribute('datetime')))
      .filter(n => !isNaN(n));
    if (times.length) newestTs = Math.max(...times);
    setInterval(pullNew, INTERVAL);
  }

  /* 增量拉取：只拿比 newestTs 新的 memo */
  async function pullNew() {
    try {
      const res = await fetch(
        `${MEMOS_API}/api/v1/memo?limit=20&rowStatus=NORMAL&createdTsAfter=${newestTs}`
      );
      if (!res.ok) return;
      const list: any[] = await res.json();
      if (!list.length) return;
      list.reverse().forEach(m => prependCard(m));
      newestTs = Math.max(newestTs, ...list.map(m => m.createdTs));
    } catch (e) {
      console.warn('[Memos pull]', e);
    }
  }

  /* 将新卡片插到顶部 */
  function prependCard(m: any) {
    const node = renderCard(m);
    $list.prepend(node);
    node.animate([{ opacity: 0, transform: 'translateY(-10px)' },
                  { opacity: 1, transform: 'none' }], { duration: 300 });
  }

  /* 渲染单条卡片（与 Astro 端逻辑保持一致） */
  function renderCard(m: any): HTMLElement {
    const card = (cardTpl.content.cloneNode(true) as DocumentFragment)
      .firstElementChild as HTMLElement;
    card.querySelector('.content')!.innerHTML = enhance(m.content);
    const timeEl = card.querySelector('time')!;
    timeEl.setAttribute('datetime', String(m.createdTs));
    timeEl.textContent = fmtTime(m.createdTs);
    return card;
  }

  /* 时间格式化 */
  function fmtTime(ts: number) {
    return new Date(ts * 1000).toLocaleString('zh-CN', {
      dateStyle: 'short', timeStyle: 'short'
    });
  }

  /* 简单增强：代码块、链接、@、# */
  function enhance(txt: string) {
    return txt
      .replace(/```(\w+)?\n([\s\S]*?)```/g, '<pre><code class="language-$1">$2</code></pre>')
      .replace(/`([^`]+)`/g, '<code>$1</code>')
      .replace(/(https?:\/\/[^\s]+)/g, '<a href="$1" target="_blank" rel="noreferrer">$1</a>')
      .replace(/(@\w+)/g,     '<span class="text-sky-600 font-semibold">$1</span>')
      .replace(/(#\w+)/g,     '<span class="text-indigo-600 font-semibold">$1</span>');
  }
</script>

<style>
  /* 让卡片更圆润一点，与 Fuwari 默认风格融合 */
  .memo-card {
    @apply bg-base-100 dark:bg-base-dark;
  }
  /* 代码块高亮（如果你已引入 Prism 或 Shiki，可删掉） */
  pre {
    @apply bg-gray-100 dark:bg-gray-800 p-3 rounded text-sm overflow-auto;
  }
  code {
    @apply text-pink-600 dark:text-pink-400;
  }
</style>

