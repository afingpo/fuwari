---
import { getEntry } from "astro:content";
import MainGridLayout from "../layouts/MainGridLayout.astro";
import ChroniclePanel from "../components/ChroniclePanel.svelte";

const chronicleData = await getEntry("spec", "chronicle");
const { development, acknowledgments } = chronicleData.data;
---

<MainGridLayout title="纪事" description="网站发展历程与鸣谢">
    <ChroniclePanel 
        title="发展历程" 
        items={development} 
        mode="timeline" 
        client:load 
    />

    <ChroniclePanel 
        title="致谢名单" 
        items={acknowledgments} 
        mode="list" 
        client:load 
    />
    
    </MainGridLayout>

