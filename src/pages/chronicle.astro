---
import MainGridLayout from '@layouts/MainGridLayout.astro';
import ChroniclePanel from '@components/ChroniclePanel.svelte';
import { i18n } from '@i18n/translation';
import I18nKey from '@i18n/i18nKey';

// 1. 改为直接通过别名静态导入 JSON（它在构建时会被正确解析和打包）
import chronicleData from '@public/chronicle.json';

// 2. 直接从导入的对象中解构数据，设置默认空数组兜底
const development = chronicleData.development || [];
const acknowledgments = chronicleData.acknowledgments || [];
---

<MainGridLayout title="纪事" description="网站发展历程与鸣谢">
    <div class="onload-animation">
        {development.length > 0 ? (
            <ChroniclePanel
                title="发展历程"
                items={development}
                client:load
            />
        ) : (
            <div class="card-base p-10 text-center opacity-50 text-[var(--text-main)]">
                暂无记录，请检查网络连接。
            </div>
        )}

        {acknowledgments.length > 0 && (
            <div class="card-base px-8 py-6 mb-6">
                <h2 class="text-2xl font-bold mb-6 text-[var(--primary)] flex items-center">
                    <div class="w-2 h-8 bg-[var(--primary)] rounded-full mr-3"></div>
                    特别鸣谢
                </h2>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
					{acknowledgments.map((ack: any) => (
						<a href={ack.link} target="_blank" class="p-4 rounded-[var(--radius-large)] border border-black/5 dark:border-white/5 hover:border-[var(--primary)] transition-all group">
                            <div class="font-bold group-hover:text-[var(--primary)] text-[var(--text-main)]">{ack.title}</div>
                            <div class="text-xs opacity-50 mb-2 text-[var(--text-main)]">@{ack.author}</div>
                            <div class="text-sm opacity-70 text-[var(--text-main)]">{ack.content}</div>
                        </a>
                    ))}
                </div>
            </div>
        )}
    </div>
</MainGridLayout>

<style>
/* 可以在这里添加针对 chronicle 页面的额外样式 */
</style>

