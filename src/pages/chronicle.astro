---
import MainGridLayout from "../layouts/MainGridLayout.astro";
import ChroniclePanel from "../components/ChroniclePanel.svelte";
import I18nKey from "../i18n/i18nKey";
import { i18n } from "../i18n/translation";

const DATA_URL = "https://raw.githubusercontent.com/afingpo/blog-data/refs/heads/main/data/chronicle.json";

let development = [];
let acknowledgments = [];

try {
    const response = await fetch(DATA_URL);
    if (!response.ok) {
        throw new Error(`Failed to fetch chronicle data: ${response.status}`);
    }
    const data = await response.json();
    development = data.development || [];
    acknowledgments = data.acknowledgments || [];
} catch (e) {
    console.error("Error loading chronicle data:", e);
}
---

<MainGridLayout title="纪事" description="网站发展历程与鸣谢">
    {development.length > 0 ? (
        <ChroniclePanel
            title="发展历程"
            items={development}
            mode="timeline"
            client:load
        />
    ) : (
        <div class="card-base p-6 text-center text-50">正在加载发展历程...</div>
    )}

    {acknowledgments.length > 0 && (
        <ChroniclePanel
            title="致谢名单"
            items={acknowledgments}
            mode="list"
            client:load
        />
    )}
</MainGridLayout>

