/* utils */
white(a)
  rgba(255, 255, 255, a)

black(a)
  rgba(0, 0, 0, a)

rainbow-light = linear-gradient(to right, oklch(0.80 0.10 0), oklch(0.80 0.10 30), oklch(0.80 0.10 60), oklch(0.80 0.10 90), oklch(0.80 0.10 120), oklch(0.80 0.10 150), oklch(0.80 0.10 180), oklch(0.80 0.10 210), oklch(0.80 0.10 240), oklch(0.80 0.10 270), oklch(0.80 0.10 300), oklch(0.80 0.10 330), oklch(0.80 0.10 360))
rainbow-dark = linear-gradient(to right, oklch(0.70 0.10 0), oklch(0.70 0.10 30), oklch(0.70 0.10 60), oklch(0.70 0.10 90), oklch(0.70 0.10 120), oklch(0.70 0.10 150), oklch(0.70 0.10 180), oklch(0.70 0.10 210), oklch(0.70 0.10 240), oklch(0.70 0.10 270), oklch(0.70 0.10 300), oklch(0.70 0.10 330), oklch(0.70 0.10 360))

:root
  --radius-large 0.25rem
  --content-delay 150ms

/* An util to define variables that vary with light and dark mode */
define(vars)
  :root
    for key, value in vars
      {key}: value[0]
  :root.dark
    for key, value in vars
      if length(value) > 1
        {key}: value[1]

define({
  /* 全局强调色：常态下为深灰/浅灰，彻底去色 */
  --primary: oklch(0.35 0 var(--hue)) oklch(0.85 0 var(--hue))
  
  /* 页面背景：浅色模式接近纯白，深色模式极深灰 */
  --page-bg: oklch(0.98 0 var(--hue)) oklch(0.12 0 var(--hue))
  --card-bg: white oklch(0.18 0 var(--hue))

  /* 按钮文字与交互内容 */
  --btn-content: oklch(0.30 0 var(--hue)) oklch(0.85 0 var(--hue))

  /* 按钮背景：利用亮度差营造点击感，但饱和度始终为 0 */
  --btn-regular-bg: oklch(0.94 0 var(--hue)) oklch(0.26 0 var(--hue))
  --btn-regular-bg-hover: oklch(0.90 0 var(--hue)) oklch(0.30 0 var(--hue))
  --btn-regular-bg-active: oklch(0.85 0 var(--hue)) oklch(0.35 0 var(--hue))

  --btn-plain-bg-hover: oklch(0.95 0 var(--hue)) oklch(0.28 0 var(--hue))
  --btn-plain-bg-active: oklch(0.92 0 var(--hue)) oklch(0.32 0 var(--hue))

  --btn-card-bg-hover: oklch(0.98 0 var(--hue)) oklch(0.25 0 var(--hue))
  --btn-card-bg-active: oklch(0.94 0 var(--hue)) oklch(0.30 0 var(--hue))

  --enter-btn-bg: var(--btn-regular-bg)
  --enter-btn-bg-hover: var(--btn-regular-bg-hover)
  --enter-btn-bg-active: var(--btn-regular-bg-active)

  /* 文字颜色：深度黑与纯白 */
  --deep-text: oklch(0.15 0 var(--hue)) oklch(0.98 0 var(--hue))
  --title-active: oklch(0.10 0 var(--hue)) oklch(1.00 0 var(--hue))

  /* 分割线与装饰线 */
  --line-divider: black(0.06) white(0.06)
  --line-color: black(0.08) white(0.08)
  --meta-divider: black(0.15) white(0.15)

  /* 代码块与行内代码 */
  --inline-code-bg: var(--btn-regular-bg)
  --inline-code-color: var(--btn-content)
  --selection-bg: oklch(0.90 0 var(--hue)) oklch(0.35 0 var(--hue))
  --codeblock-selection: oklch(0.40 0 var(--hue))
  --codeblock-bg: oklch(0.15 0 var(--hue)) oklch(0.15 0 var(--hue))
  --codeblock-topbar-bg: oklch(0.25 0 var(--hue)) oklch(0.10 0 var(--hue))

  --license-block-bg: black(0.02) var(--codeblock-bg)

  /* 链接装饰：使用亮度区分而非色相 */
  --link-underline: oklch(0.90 0 var(--hue)) oklch(0.35 0 var(--hue))
  --link-hover: oklch(0.85 0 var(--hue)) oklch(0.40 0 var(--hue))
  --link-active: oklch(0.80 0 var(--hue)) oklch(0.45 0 var(--hue))

  --float-panel-bg: white oklch(0.20 0 var(--hue))

  /* 滚动条 */
  --scrollbar-bg-light: black(0.3)
  --scrollbar-bg-hover-light: black(0.4)
  --scrollbar-bg-active-light: black(0.5)
  --scrollbar-bg-dark: white(0.3)
  --scrollbar-bg-hover-dark: white(0.4)
  --scrollbar-bg-active-dark: white(0.5)

  --scrollbar-bg: var(--scrollbar-bg-light) var(--scrollbar-bg-dark)
  --scrollbar-bg-hover: var(--scrollbar-bg-hover-light) var(--scrollbar-bg-hover-dark)
  --scrollbar-bg-active: var(--scrollbar-bg-active-light) var(--scrollbar-bg-active-dark)

  /* 进度条：如果你想连顶部的彩虹进度条都变灰，可以改为单一灰度 */
  --color-selection-bar: #888 #444

  --display-light-icon: 1 0
  --display-dark-icon: 0 1

  /* 提示框（Admonitions）：即使是警告也要黑白，靠亮度识别 */
  --admonitions-color-tip: oklch(0.45 0 0) oklch(0.75 0 0)
  --admonitions-color-note: oklch(0.40 0 0) oklch(0.70 0 0)
  --admonitions-color-important: oklch(0.35 0 0) oklch(0.65 0 0)
  --admonitions-color-warning: oklch(0.30 0 0) oklch(0.60 0 0)
  --admonitions-color-caution: oklch(0.25 0 0) oklch(0.55 0 0)

  /* 目录（TOC） */
  --toc-badge-bg: oklch(0.90 0 var(--hue)) var(--btn-regular-bg)
  --toc-btn-hover: oklch(0.92 0 var(--hue)) oklch(0.24 0 var(--hue))
  --toc-btn-active: oklch(0.88 0 var(--hue)) oklch(0.28 0 var(--hue))
  --toc-width: calc((100vw - var(--page-width)) / 2 - 1rem)
  --toc-item-active: oklch(0.30 0 var(--hue)) oklch(0.85 0 var(--hue))
})

