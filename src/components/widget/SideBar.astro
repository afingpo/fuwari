---
import type { MarkdownHeading } from "astro";
import Categories from "./Categories.astro";
import Profile from "./Profile.astro";
import Tag from "./Tags.astro";
import UmamiStatus from "./UmamiStatus.astro";
import Music from "./Music.astro";
import ExtraBlock from "./ExtraBlock.astro";

interface Props {
	class?: string;
	headings?: MarkdownHeading[];
};

const className = Astro.props.class;
const headings = Astro.props.headings;
---
<div id="sidebar" class:list={[className, "w-full"]}>
	<div class="flex flex-col w-full gap-4 mb-4">
		<Profile></Profile>
	</div>
	<div id="sidebar-sticky" class="transition-all duration-700 flex flex-col w-full gap-4 top-4 sticky top-4">
		<Categories class="onload-animation" style="animation-delay: 150ms"></Categories>
		<!-- <Tag class="onload-animation" style="animation-delay: 200ms"></Tag>  -->
		<!-- <UmamiStatus class="onload-animation" style="animation-delay: 200ms" /> -->
		<!-- <Music class="onload-animation" style="animation-delay: 200ms"></Music> -->
		<ExtraBlock class="onload-animation" style="animation-delay: 150ms"></ExtraBlock>
	</div>
</div>
