---
interface Props {
  path: string
}
const { path } = Astro.props

// 直接在这里硬编码你的后端 URL，不再引用 config.ts
const twikooConfig = {
  // envId: 'https://twikoo3-060502-netlify.netlify.app/.netlify/functions/twikoo', // Netlify
  // envId: 'https://twikoo3-vercel.afipo.top', // Vercel
  envId: 'https://twikoo3-260502-vercel-ke3dc0xsu-han-lius-projects.vercel.app/',
  lang: 'zh-CN',
  el: '#tcomment',
  path: path,
}

---

<div id="tcomment"></div>

<script 
  src="https://cdn.jsdelivr.net/npm/twikoo@1.7.7/dist/twikoo.min.js" 
  integrity="sha384-CXhXF3hh7LQyBPKnwgq/KgbcvoQcedpFyE4YuV8GLc+pKO1vCqQpuyNQ60/UblNE"
  crossorigin="anonymous"
></script>

<script is:inline define:vars={{ twikooConfig }}>
  function initTwikoo() {
    const el = document.querySelector('#tcomment');
    if (el && window.twikoo) {
      window.twikoo.init(twikooConfig);
    }
  }
  initTwikoo();
  document.addEventListener('astro:after-swap', initTwikoo);
</script>

