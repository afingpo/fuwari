---
// ✅ 无 props，硬编码，最简版
---

<div id="giscus"></div>

<script>
  const script = document.createElement('script');
  script.src = 'https://giscus.app/client.js';
  script.setAttribute('data-repo', 'afingpo/blog-data');
  script.setAttribute('data-repo-id', 'R_kgDOQaktMA');
  script.setAttribute('data-category', 'Announcements');
  script.setAttribute('data-category-id', 'DIC_kwDOQaktMM4CyEBL');
  script.setAttribute('data-mapping', 'pathname');
  script.setAttribute('data-strict', '1');
  script.setAttribute('data-reactions-enabled', '1');
  script.setAttribute('data-emit-metadata', '0');
  script.setAttribute('data-input-position', 'top');
  script.setAttribute('data-theme', document.documentElement.classList.contains('dark') ? 'dark' : 'light');
  script.setAttribute('data-lang', 'zh-CN');
  script.setAttribute('data-loading', 'lazy');
  script.crossOrigin = 'anonymous';
  script.async = true;
  
  document.getElementById('giscus').appendChild(script);

  // ✅ 主题切换（保留核心功能）
  new MutationObserver(() => {
    const frame = document.querySelector('iframe.giscus-frame');
    if (frame?.contentWindow) {
      frame.contentWindow.postMessage({
        giscus: { setConfig: { theme: document.documentElement.classList.contains('dark') ? 'dark' : 'light' } }
      }, 'https://giscus.app');
    }
  }).observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });
</script>

