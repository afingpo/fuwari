---
import { commentConfig } from '@/config'

interface Props {
  path: string
}

const config = commentConfig?.giscus || {}
// ✅ 使用你的 Workers 代理域名
const GISCUS_ORIGIN = 'https://giscus-proxy.465332.xyz'
---

<div id="giscus" class="giscus-wrapper loading"></div>
<script is:inline define:vars={{ 
  ...config,
  origin: GISCUS_ORIGIN,
  path: Astro.props.path 
}}>
  // 动态创建 script，走代理域名
  const script = document.createElement('script');
  script.src = `${origin}/client.js`;
  script.setAttribute('data-repo', config.repo);
  script.setAttribute('data-repo-id', config.repoId);
  script.setAttribute('data-category', config.category);
  script.setAttribute('data-category-id', config.categoryId);
  script.setAttribute('data-mapping', 'pathname');
  script.setAttribute('data-strict', '1');
  script.setAttribute('data-reactions-enabled', '1');
  script.setAttribute('data-emit-metadata', '0');
  script.setAttribute('data-input-position', 'top');
  script.setAttribute('data-theme', 'fro');
  script.setAttribute('data-lang', 'zh-CN');
  script.setAttribute('data-loading', 'lazy');
  script.crossOrigin = 'anonymous';
  script.async = true;
  
  document.getElementById('giscus').appendChild(script);
</script>

<style is:global>
  .giscus-wrapper {
    min-height: 400px;
    opacity: 0;
    transition: opacity 0.3s ease;
  }
  .giscus-wrapper.loaded {
    opacity: 1;
  }
</style>

<script>
  document.addEventListener('giscus:ready', () => {
    document.querySelector('.giscus-wrapper')?.classList.add('loaded');
  });
  
  // ✅ 关键：拦截 iframe 请求，也走代理
  document.addEventListener('giscus:load', () => {
    const iframe = document.querySelector('iframe.giscus-frame');
    if (iframe && iframe.src.includes('giscus.app')) {
      iframe.src = iframe.src.replace('https://giscus.app', origin);
    }
  });
</script>

