---
interface Props {
  path: string  // 保持接口一致性
}

// ✅ 所有配置直接写死，一行一个，清晰明了
const GISCUS_CONFIG = {
  "src": "https://giscus.app/client.js",
  "data-repo": "afingpo/blog-data",
  "data-repo-id": "R_kgDOQaktMA",
  "data-category": "Announcements",
  "data-category-id": "DIC_kwDOQaktMM4CyEBL",
  "data-mapping": "pathname",
  "data-strict": "1",
  "data-reactions-enabled": "1",
  "data-emit-metadata": "0",
  "data-input-position": "top",
  "data-theme": "fro",
  "data-lang": "zh-CN",
  "data-loading": "lazy",
  "crossorigin": "anonymous",
  async: true,
}
---

<div class="giscus-wrapper loading"></div>

<script is:inline define:vars={{ config: GISCUS_CONFIG }}>
  const script = document.createElement('script');
  script.src = config.src;
  
  // ✅ 直接遍历配置对象，一行代码设置所有属性
  Object.entries(config).forEach(([key, value]) => {
    if (key !== 'src') script.setAttribute(key, value);
  });
  
  document.querySelector('.giscus-wrapper').appendChild(script);
</script>

<style is:global>
  .giscus-wrapper {
    min-height: 400px;
    opacity: 0;
    transition: opacity 0.3s ease;
  }
  .giscus-wrapper.loaded {
    opacity: 1;
  }
</style>

<script>
  document.addEventListener('giscus:ready', () => {
    document.querySelector('.giscus-wrapper')?.classList.add('loaded');
  });
</script>

