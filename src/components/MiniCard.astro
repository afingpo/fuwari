---
import { Icon } from "astro-icon/components";
import path from "node:path";
import ImageWrapper from "./misc/ImageWrapper.astro";
import { getDir } from "../utils/url-utils";
import { fade } from "astro:transitions";

interface Props {
    class?: string;
    entry?: any;
    title: string;
    url: string;
    published?: Date;
    updated?: Date;
    tags?: string[];
    category?: string | null;
    image?: string;
    description?: string;
    words?: number;
    minutes?: number;
    showEnterBtn?: boolean;
}

const {
    entry,
    title,
    url,
    published,
    updated,
    tags,
    category,
    image,
    description,
    words,
    minutes,
    showEnterBtn = false,
    class: className
} = Astro.props;

const hasCover = !!image;
const displayDate = published ? new Date(published).toISOString().split('T')[0] : null;
---

<div class:list={["card-base flex flex-col md:flex-row w-full rounded-[var(--radius-large)] overflow-hidden relative group transition-all duration-300", className]}>
    
    <div class:list={[
        "pl-6 md:pl-7 pr-6 py-5 flex flex-col justify-center relative w-full", // 修改点：md:pl-9 -> md:pl-7
        { "md:w-[calc(100%_-_28%_-_12px)]": hasCover }
    ]}>
        <a href={url} class="transition w-full flex items-center font-bold text-xl text-90
                hover:text-[var(--primary)] dark:hover:text-[var(--primary)]
                active:text-[var(--title-active)]
                relative
                before:content-['']
                before:absolute
                before:top-[calc(50%-4px)]
                before:left-[-18px]
                before:w-2
                before:h-2
                before:rounded-[2px]
                before:bg-[var(--primary)]
                before:hidden md:before:block
        ">
            {title}
            <Icon name="material-symbols:chevron-right-rounded" 
                  class="text-[var(--primary)] text-2xl ml-0.5 shrink-0 transition-transform group-hover:translate-x-1" />
        </a>

        {(displayDate || category) && (
            <div class="flex flex-wrap gap-3 items-center mt-2 text-xs opacity-50 font-mono">
                {displayDate && <span>{displayDate}</span>}
                {category && (
                    <>
                        <span class="opacity-30">|</span>
                        <span class="hover:text-[var(--primary)] cursor-pointer">{category}</span>
                    </>
                )}
            </div>
        )}

        {description && (
            <div class="text-sm text-75 mt-2 line-clamp-2 md:line-clamp-1 opacity-70">
                {description}
            </div>
        )}

        {tags && tags.length > 0 && (
            <div class="flex flex-wrap gap-2 mt-2">
                {tags.map(tag => (
                    <span class="text-[10px] bg-black/5 dark:bg-white/5 px-2 py-0.5 rounded-full opacity-60">#{tag}</span>
                ))}
            </div>
        )}

        {(words || minutes) && (
            <div class="text-[10px] opacity-30 mt-2 flex gap-2">
                {words && <span>{words} 字</span>}
                {minutes && <span>{minutes} 分钟阅读</span>}
            </div>
        )}
    </div>

    {hasCover && (
        <a href={url} class="hidden md:block w-[28%] relative overflow-hidden group-hover:brightness-90 transition-all">
            <ImageWrapper
                src={image!}
                basePath={entry ? path.join("content/posts/", getDir(entry.id)) : ""}
                alt={title}
                class="w-full h-full object-cover absolute inset-0"
            />
        </a>
    )}
</div>

<style>
    .card-base {
        background-color: var(--card-bg);
    }
</style>

