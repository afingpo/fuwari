---
import { Icon } from "astro-icon/components";
import path from "node:path";
import ImageWrapper from "./misc/ImageWrapper.astro";
import { getDir } from "../utils/url-utils";
import { i18n } from "../i18n/translation";
import I18nKey from "../i18n/i18nKey";

interface Props {
    class?: string;
    entry?: any;
    title: string;
    url: string;
    published?: Date;
    updated?: Date;
    tags?: string[];
    category?: string | null;
    image?: string;
    description?: string;
    words?: number;
    minutes?: number;
}

const {
    entry,
    title,
    url,
    published,
    tags,
    category,
    image,
    description,
    words,
    minutes,
    class: className
} = Astro.props;

const hasCover = !!image;
const displayDate = published ? new Date(published).toISOString().split('T')[0] : null;
---

<div class:list={["card-base flex flex-col md:flex-row w-full rounded-[var(--radius-large)] overflow-hidden relative group transition-all duration-300", className]}>
    
    <div class:list={[
        "pl-6 md:pl-7 pr-6 py-5 flex flex-col justify-center relative w-full",
        { "md:w-[calc(100%_-_28%_-_12px)]": hasCover }
    ]}>
        <a href={url} class="transition w-full flex items-center font-bold text-xl text-90 hover:text-[var(--primary)] active:text-[var(--title-active)] relative before:content-[''] before:absolute before:top-[calc(50%-4px)] before:left-[-18px] before:w-2 before:h-2 before:rounded-[2px] before:bg-[var(--primary)] before:hidden md:before:block">
            {title}
            <Icon name="material-symbols:chevron-right-rounded" class="text-[var(--primary)] text-2xl ml-0.5 shrink-0 transition-transform group-hover:translate-x-1" />
        </a>

        <div class="flex flex-wrap gap-2 items-center mt-2 text-[10px] md:text-xs opacity-50 font-mono">
            {displayDate && <span>{displayDate}</span>}
            {category && (
                <>
                    <span class="opacity-30">|</span>
                    <span class="hover:opacity-100 cursor-default">{category}</span>
                </>
            )}
            {words && (
                <>
                    <span class="opacity-30">|</span>
                    <span>{words} {i18n(I18nKey.wordsCount)}</span>
                </>
            )}
        </div>

        {description && (
            <div class="text-sm text-75 mt-2 line-clamp-2 md:line-clamp-1 opacity-70">
                {description}
            </div>
        )}

        {tags && tags.length > 0 && (
            <div class="flex flex-wrap gap-2 mt-3">
                {tags.map(tag => (
                    <div class="flex items-center text-[10px] font-bold
                        bg-[var(--primary-light)] text-[var(--primary)] 
                        px-2 py-0.5 rounded-md border border-[var(--primary-light)]
                        transition-colors hover:brightness-95">
                        <Icon name="material-symbols:tag-rounded" class="mr-0.5" />
                        {tag}
                    </div>
                ))}
            </div>
        )}
    </div>

    {hasCover && (
        <a href={url} class="hidden md:block w-[28%] relative overflow-hidden group-hover:brightness-90 transition-all">
            <ImageWrapper src={image!} basePath={entry ? path.join("content/posts/", getDir(entry.id)) : ""} alt={title} class="w-full h-full object-cover absolute inset-0" />
        </a>
    )}
</div>

<style>
    .card-base { background-color: var(--card-bg); }
</style>

