---
import { commentConfig } from '@/config'
interface Props { path: string }
const { envId, lang = 'zh-CN', region = '' } = commentConfig.twikoo || {}
---
<div id="tcomment" class="w-full mt-8"></div>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/twikoo@1/dist/twikoo.css" />
<script define:vars={{ envId, lang, region, path: Astro.props.path }} type="module">
  alert('Twikoo envId=' + envId);
  import twikoo from 'https://cdn.jsdelivr.net/npm/twikoo@1/dist/twikoo.min.js'
  twikoo.init({
    envId,
    region,
    lang,
    el: '#tcomment',
    path: Astro.props.path,
    darkMode: document.documentElement.classList.contains('dark')
  })
  document.addEventListener('astro:after-swap', () => {
    twikoo.init({ envId, region, lang, path: Astro.props.path, el: '#tcomment' })
  })
</script>

