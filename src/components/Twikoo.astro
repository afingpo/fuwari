---
import { commentConfig } from '@/config'
const { envId, lang = 'zh-CN', region = '' } = commentConfig.twikoo || {}
// ↑ 必须在这里解构，define:vars 只能引用顶层变量
---


<script define:vars={{ envId, lang, region, path: Astro.props.path }} type="module">
  /* ===== 调试 ===== */
  console.log('[Twikoo] envId =', envId);
  console.log('[Twikoo] path  =', path);

  import twikoo from 'https://cdn.jsdelivr.net/npm/twikoo@1/dist/twikoo.min.js';

  twikoo.init({
    envId,
    region,
    lang,
    el: '#tcomment',
    path,
    darkMode: document.documentElement.classList.contains('dark')
  });

  /* 暗色切换后重初始化 */
  document.addEventListener('astro:after-swap', () => {
    twikoo.init({
      envId,
      region,
      lang,
      el: '#tcomment',
      path,
      darkMode: document.documentElement.classList.contains('dark')
    });
  });
</script>

