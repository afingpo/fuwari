---
import type { CollectionEntry } from "astro:content";
import { getPostUrlBySlug } from "@utils/url-utils";
import PostCard from "./PostCard.astro";
import MiniCard from "./MiniCard.astro";

const { page } = Astro.props;

let delay = 0;
const interval = 50;

// 预处理数据，判断哪些 essay 需要占满全列
const posts = page.data;
---

<div class="transition grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
    {posts.map((entry: CollectionEntry<"posts">, index: number) => {
        const isEssay = entry.data.pType === "essay";
        
        // 逻辑：如果是最后一个元素，且 index 是偶数（代表它是单出来的一个），则占满两列
        // 注意：index 从 0 开始，0, 2, 4 是每一行的第一个
        const isLoneEssay = isEssay && (index === posts.length - 1) && (index % 2 === 0);

        return isEssay ? (
            <div class:list={[
                "flex",
                { "md:col-span-2": isLoneEssay }
            ]}>
                <MiniCard
                    entry={entry}
                    title={entry.data.title}
                    url={getPostUrlBySlug(entry.slug)}
                    published={entry.data.published}
                    tags={entry.data.tags}
                    category={entry.data.category}
                    description={entry.data.description}
                    words={entry.data.words}
                    minutes={entry.data.minutes}
                    showEnterBtn={true}
                    class:list="onload-animation w-full"
                    style={`animation-delay: calc(var(--content-delay) + ${delay++ * interval}ms);`}
                />
            </div>
        ) : (
            /* 普通文章 PostCard 始终占满两列（独占一行） */
            <div class="md:col-span-2 flex">
                <PostCard
                    entry={entry}
                    title={entry.data.title}
                    tags={entry.data.tags}
                    category={entry.data.category}
                    published={entry.data.published}
                    updated={entry.data.updated}
                    url={getPostUrlBySlug(entry.slug)}
                    image={entry.data.image}
                    description={entry.data.description}
                    draft={entry.data.draft}
                    class:list="onload-animation w-full"
                    style={`animation-delay: calc(var(--content-delay) + ${delay++ * interval}ms);`}
                ></PostCard>
            </div>
        )
    })}
</div>

